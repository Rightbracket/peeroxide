FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y \
    iptables \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY tests/node/package.json tests/node/package-lock.json* ./
RUN npm install

COPY tests/node/ ./
COPY tests/docker/scripts/ ./scripts/

# No ENTRYPOINT: docker-compose.nat.yml's `command:` (e.g. ["node",
# "nat-bootstrap.js", ...]) must run directly. An `ENTRYPOINT ["/bin/bash"]`
# here would instead make `command` a list of *arguments to bash*, so
# `command: ["node", ...]` would try (and fail) to run `bash node ...`,
# i.e. execute the `node` binary as a shell script.
